# ═══ CarClaw 环境变量 ═══

# LLM 配置 (DeepSeek API，兼容 OpenAI 格式)
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# STT 配置 (MVP 阶段可留空，使用 Text Channel)
STT_ENGINE=mock
# STT_ENGINE=whisper
# WHISPER_MODEL_PATH=./models/ggml-base.bin

# TTS 配置 (MVP 阶段使用 console 输出)
TTS_ENGINE=console
# TTS_ENGINE=cosyvoice
# COSYVOICE_API_URL=http://localhost:8080

# 日志级别
LOG_LEVEL=info
