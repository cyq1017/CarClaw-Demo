{
  "name": "carclaw-demo",
  "version": "0.2.0",
  "description": "CarClaw - 开源车机 AI 助手，复用 OpenClaw 核心架构",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "eval": "tsx scripts/eval-router.ts",
    "web": "tsx src/server.ts"
  },
  "keywords": [
    "car",
    "ai",
    "voice-assistant",
    "vehicle",
    "openclaw"
  ],
  "license": "MIT",
  "dependencies": {
    "openai": "^4.80.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}